# Local development defaults. Copy to .env.local and adjust if needed.

# iron-session encryption secret (must be 32+ chars). Replace in any real deployment.
SESSION_SECRET=charting-dev-secret-change-me-please-32chars

# DynamoDB Local endpoint. On AWS, remove this so the SDK targets real DynamoDB.
DYNAMODB_ENDPOINT=http://localhost:8000
TABLE_NAME=charting
AWS_REGION=us-east-1
